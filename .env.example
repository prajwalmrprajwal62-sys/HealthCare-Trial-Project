# Drishti Health — Environment Variables
# Copy this to .env and fill in your keys

# Bhashini API (https://bhashini.gov.in/ulca)
BHASHINI_USER_ID=
BHASHINI_API_KEY=
BHASHINI_PIPELINE_ID=

# Sarvam AI (https://sarvam.ai)
SARVAM_API_KEY=

# ABDM Sandbox (https://sandbox.abdm.gov.in)
ABDM_CLIENT_ID=
ABDM_CLIENT_SECRET=
ABDM_BASE_URL=https://dev.abdm.gov.in/gateway

# App Config
APP_MODE=demo  # demo | production
OFFLINE_MODE=true
DATABASE_PATH=data/drishti.db
MODEL_DIR=models/
